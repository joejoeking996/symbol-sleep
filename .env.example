# Local prototype database.
# For production, prefer PostgreSQL and disable schema push in src/payload.config.ts.
DATABASE_URL=file:./company-site.db
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Used to encrypt Payload JWT tokens. Replace with a long random value per environment.
PAYLOAD_SECRET=replace-with-a-long-random-secret

# Public canonical site URL. No trailing slash.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs.
CRON_SECRET=replace-with-a-long-random-secret

# Used to validate draft preview requests.
PREVIEW_SECRET=replace-with-a-long-random-secret
